	"ART_ru_ft_N_td_d7_4_1": "球隊3",
	"ART_ru_ft_N_td_d7_4_2": "82",
	"ART_ru_ft_N_td_d7_4_3": "5",
	"ART_ru_ft_N_td_d7_4_4": "87",
	"ART_ru_ft_N_td_d7_4_5": "第4",
	"ART_ru_ft_N_td_d7_5_1": "球隊4",
	"ART_ru_ft_N_td_d7_5_2": "79",
	"ART_ru_ft_N_td_d7_5_3": "15",
