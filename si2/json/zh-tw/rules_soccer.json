	"ART_ru_ft_N_td_d7_3_1": "球隊2",
	"ART_ru_ft_N_td_d7_3_2": "85",
	"ART_ru_ft_N_td_d7_3_3": "0",
	"ART_ru_ft_N_td_d7_3_4": "85",
