	"ART_ru_ft_G_l_3_2": "球队B",
	"ART_ru_ft_G_l_3_3": "平局",

	"ART_ru_ft_G_m": "第一张罚牌时间",
	"ART_ru_ft_G_m_1": "预测出示首个罚牌的时间。",
	"ART_ru_ft_G_m_2": "选项可列为：",
